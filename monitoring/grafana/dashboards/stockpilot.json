{
  "annotations": { "list": [] },
  "editable": true,
  "title": "StockPilot 관측성",
  "uid": "stockpilot-observability",
  "tags": ["stockpilot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "추천 캐시 적중률 (Cache-Aside)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(stockpilot_recommendation_cache_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(stockpilot_recommendation_cache_total[5m])), 1)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "추천 캐시 hit/miss rate",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{result}}",
          "expr": "sum by (result) (rate(stockpilot_recommendation_cache_total[1m]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "추천 계산 지연 p95 (캐시 미스 경로)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum(rate(stockpilot_recommendation_compute_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP 요청 처리량 (uri별)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{uri}}",
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count[1m]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "좋아요 · 조회수 · 알림 발화 rate",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "legendFormat": "좋아요", "expr": "rate(stockpilot_like_registered_total[1m])" },
        { "refId": "B", "legendFormat": "조회수", "expr": "rate(stockpilot_ranking_view_total[1m])" },
        { "refId": "C", "legendFormat": "알림 발화", "expr": "rate(stockpilot_alert_triggered_total[1m])" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP 지연 p95 (uri별)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{uri}}",
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket[5m])))"
        }
      ]
    }
  ]
}
